{
    "name": "lolissr/lolissr",
    "description": "Site personnel",
    "license": "proprietary",
    "type": "project",

    "require": {
        "php": "^8.3"
    },

    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0"
    },

    "autoload": {
        "psr-4": {
            "App\\": "App/",
            "Framework\\": "Framework/"
        }
